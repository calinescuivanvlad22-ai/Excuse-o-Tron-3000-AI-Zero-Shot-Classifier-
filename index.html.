<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detector de Scuze Penibile AI</title>
    <style>
        :root {
            --bg: #1e1e2f;
            --text: #f8f8f2;
            --primary: #ff79c6;
            --secondary: #bd93f9;
            --card: #282a36;
        }
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background-color: var(--bg); 
            color: var(--text); 
            text-align: center; 
            padding: 40px 20px; 
            margin: 0;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            background: var(--card);
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
        h1 { margin-top: 0; color: var(--primary); }
        textarea { 
            width: 90%; 
            height: 100px; 
            font-size: 16px; 
            padding: 15px; 
            margin: 20px 0; 
            border-radius: 10px; 
            border: 2px solid #44475a; 
            background: var(--bg);
            color: white;
            resize: none;
        }
        textarea:focus { outline: none; border-color: var(--secondary); }
        button { 
            padding: 15px 30px; 
            font-size: 18px; 
            font-weight: bold;
            background: linear-gradient(45deg, var(--primary), var(--secondary)); 
            color: white; 
            border: none; 
            cursor: pointer; 
            border-radius: 8px; 
            transition: 0.3s;
        }
        button:hover { transform: scale(1.05); }
        button:disabled { background: #6272a4; cursor: not-allowed; transform: none; }
        #rezultat { 
            margin-top: 25px; 
            font-size: 20px; 
            padding: 15px;
            border-radius: 8px;
            display: none;
        }
        .categoria-castigatoare { font-size: 28px; font-weight: bold; color: #50fa7b; margin: 10px 0;}
        .loading { color: #f1fa8c; font-style: italic; font-size: 18px; }
    </style>
</head>
<body>

    <div class="container">
        <h1>Excuse-o-Tron 3000 🎓</h1>
        <p>Aplicație de clasificare <strong>Zero-Shot</strong> rulată 100% în browser.</p>
        <p style="font-size: 0.9em; color: #6272a4;">*Scrieți scuza în limba engleză pentru acuratețe maximă a modelului AI.</p>
        
        <textarea id="textInput" placeholder="Ex: I couldn't finish the project because my cat unplugged the Wi-Fi router..."></textarea>
        <br>
        <button id="analyzeBtn" disabled>⚙️ Se încarcă AI-ul...</button>
        
        <div id="rezultat"></div>
    </div>

    <!-- Importăm biblioteca Transformers.js -->
    <script type="module">
        import { pipeline } from 'https://cdn.jsdelivr.net/npm/@xenova/transformers@2.14.0';

        const button = document.getElementById('analyzeBtn');
        const rezultatDiv = document.getElementById('rezultat');
        const textInput = document.getElementById('textInput');

        let classifier;

        // Categoriile noastre amuzante
        const categorii = [
            "technical issue or bad internet", 
            "blatant lie or made up story", 
            "pure laziness disguised as an excuse", 
            "pet related excuse", 
            "valid and believable reason"
        ];

        // Încărcăm modelul de AI în browser
        async function loadModel() {
            try {
                // Folosim zero-shot classification
                classifier = await pipeline('zero-shot-classification');
                button.innerHTML = '🔍 Analizează Scuza';
                button.disabled = false;
            } catch (error) {
                button.innerHTML = "Eroare la încărcare";
                console.error("Eroare AI:", error);
            }
        }

        button.addEventListener('click', async () => {
            const text = textInput.value;
            if (!text) return alert("Scrie o scuză mai întâi!");

            rezultatDiv.style.display = 'block';
            rezultatDiv.innerHTML = '<div class="loading">Analizez gradul de penibil... ⏳</div>';
            button.disabled = true;
            
            // Rulăm AI-ul pe textul dat în raport cu categoriile noastre
            const result = await classifier(text, categorii);
            
            // Extragem cea mai probabilă categorie
            const categoriaTop = result.labels[0];
            const probabilitate = Math.round(result.scores[0] * 100);

            // Traducem categoria în română pentru afișare
            let categorieRo = "";
            let emoji = "";
            if (categoriaTop.includes("technical issue")) { categorieRo = "Problemă Tehnică Clasică"; emoji = "🔌"; }
            else if (categoriaTop.includes("blatant lie")) { categorieRo = "Minciună Gogonată"; emoji = "🤥"; }
            else if (categoriaTop.includes("pure laziness")) { categorieRo = "Lene Absolută"; emoji = "🦥"; }
            else if (categoriaTop.includes("pet related")) { categorieRo = "A dat vina pe animal"; emoji = "🐕"; }
            else { categorieRo = "Scuză Validă (Credibil)"; emoji = "✅"; }

            rezultatDiv.innerHTML = `
                <div>Verdictul AI-ului:</div>
                <div class="categoria-castigatoare">${emoji} ${categorieRo}</div>
                <div style="font-size: 16px; color: #8be9fd;">Siguranță model: ${probabilitate}%</div>
            `;
            button.disabled = false;
        });

        loadModel();
    </script>

</body>
</html>
