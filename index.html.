<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Excuse Detector</title>
    <style>
        :root {
            --bg: #1e1e2f;
            --text: #f8f8f2;
            --primary: #ff79c6;
            --secondary: #bd93f9;
            --card: #282a36;
        }
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background-color: var(--bg); 
            color: var(--text); 
            text-align: center; 
            padding: 40px 20px; 
            margin: 0;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            background: var(--card);
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
        h1 { margin-top: 0; color: var(--primary); }
        textarea { 
            width: 90%; 
            height: 100px; 
            font-size: 16px; 
            padding: 15px; 
            margin: 20px 0; 
            border-radius: 10px; 
            border: 2px solid #44475a; 
            background: var(--bg);
            color: white;
            resize: none;
        }
        textarea:focus { outline: none; border-color: var(--secondary); }
        button { 
            padding: 15px 30px; 
            font-size: 18px; 
            font-weight: bold;
            background: linear-gradient(45deg, var(--primary), var(--secondary)); 
            color: white; 
            border: none; 
            cursor: pointer; 
            border-radius: 8px; 
            transition: 0.3s;
        }
        button:hover { transform: scale(1.05); }
        button:disabled { background: #6272a4; cursor: not-allowed; transform: none; }
        #result { 
            margin-top: 25px; 
            font-size: 20px; 
            padding: 15px;
            border-radius: 8px;
            display: none;
        }
        .winning-category { font-size: 28px; font-weight: bold; color: #50fa7b; margin: 10px 0;}
        .loading { color: #f1fa8c; font-style: italic; font-size: 18px; }
    </style>
</head>
<body>

    <div class="container">
        <h1>Excuse-o-Tron 3000 🎓</h1>
        <p>A <strong>Zero-Shot Classification</strong> app running 100% in your browser.</p>
        
        <textarea id="textInput" placeholder="Ex: I couldn't finish the project because my cat unplugged the Wi-Fi router..."></textarea>
        <br>
        <button id="analyzeBtn" disabled>⚙️ Loading AI Engine...</button>
        
        <div id="result"></div>
    </div>

    <!-- Import Transformers.js -->
    <script type="module">
        import { pipeline } from 'https://cdn.jsdelivr.net/npm/@xenova/transformers@2.14.0';

        const button = document.getElementById('analyzeBtn');
        const resultDiv = document.getElementById('result');
        const textInput = document.getElementById('textInput');

        let classifier;

        // The categories the AI will use to classify the excuse
        const categories = [
            "technical issue or bad internet", 
            "blatant lie or made up story", 
            "pure laziness disguised as an excuse", 
            "pet related excuse", 
            "valid and believable reason"
        ];

        // Load the AI model into the browser
        async function loadModel() {
            try {
                classifier = await pipeline('zero-shot-classification');
                button.innerHTML = '🔍 Analyze Excuse';
                button.disabled = false;
            } catch (error) {
                button.innerHTML = "Error loading model";
                console.error("AI Error:", error);
            }
        }

        button.addEventListener('click', async () => {
            const text = textInput.value;
            if (!text) return alert("Please type an excuse first!");

            resultDiv.style.display = 'block';
            resultDiv.innerHTML = '<div class="loading">Analyzing the cringe level... ⏳</div>';
            button.disabled = true;
            
            // Run the AI model
            const result = await classifier(text, categories);
            
            // Extract the top category
            const topCategory = result.labels[0];
            const probability = Math.round(result.scores[0] * 100);

            // Format for UI presentation
            let displayCategory = "";
            let emoji = "";
            if (topCategory.includes("technical issue")) { displayCategory = "Classic Tech Issue"; emoji = "🔌"; }
            else if (topCategory.includes("blatant lie")) { displayCategory = "Blatant Lie"; emoji = "🤥"; }
            else if (topCategory.includes("pure laziness")) { displayCategory = "Pure Laziness"; emoji = "🦥"; }
            else if (topCategory.includes("pet related")) { displayCategory = "Blamed the Pet"; emoji = "🐕"; }
            else { displayCategory = "Valid Excuse (Credible)"; emoji = "✅"; }

            resultDiv.innerHTML = `
                <div>AI Verdict:</div>
                <div class="winning-category">${emoji} ${displayCategory}</div>
                <div style="font-size: 16px; color: #8be9fd;">Model Confidence: ${probability}%</div>
            `;
            button.disabled = false;
        });

        loadModel();
    </script>

</body>
</html>
